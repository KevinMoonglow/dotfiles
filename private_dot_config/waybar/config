[{
	// vim: ft=json5
	
    "layer": "top", // Waybar at top layer
    "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 32, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces", "sway/workspaces", "niri/workspaces", "hyprland/submap", "sway/mode", "hyprland/window", "sway/window", "niri/window"],
    "modules-center": [],
    "modules-right": ["mpd", "idle_inhibitor", "pulseaudio", "memory", "clock", "tray"],
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "warp-on-scroll": false,
        "format": "{icon}",
        "format-icons": {
             "1:ΎΑΧέΓΒ": "ΎΑΧέΓΒ",
             "2:ΎΕκέΓΓ": "ΎΕκέΓΓ",
             "3:ΎΓΗέΓΔ": "ΎΓΗέΓΔ",
             "4:ΎΚσέΓΕ": "ΎΚσέΓΕ",
             "5:ΎΕδέΓΖ": "ΎΕδέΓΖ",
             "6:ΌΙτέΓΗ": "ΌΙτέΓΗ",
        }
    },
    // Modules configuration
	"hyprland/workspaces": {
		"format": "{icon}<sub>{id}</sub>",
		"format-icons": {
             "1": "ΎΑΧ",
             "2": "ΎΕκ",
             "3": "ΎΓΗ",
             "4": "ΎΚσ",
             "5": "ΎΕδ",
             "6": "ΌΙτ",
             "default": "ΎΕΣ"
		},
	},
	"niri/workspaces": {
		"format": "{icon}<sub>{index}</sub>",
		"format-icons": {
			"home": "ΎΑΧ",
			"dev": "ΎΕκ",
			"chat": "ΎΓΗ",
			"browser": "≤░Ι╣",
			"art": "≤░Πα",
			"gaming": "≤░ψΚ",
			"scratch": "ΎΚΚ",
			"default": "ΎΦΝ",
		}
	},

	"hyprland/workspaces#icons": {
		"format": "{windows}",
		"format-window-separator": " ",
		"window-rewrite-default": "ΎΒβ",
		"window-rewrite": {
			"class<firefox>": "ΎΚσ",
			"class<Thunar>": "ΌαΥ",
		},
		"active-only": true,
	},

	"hyprland/window": {
		"format": "{}",
		"rewrite": {
			"(.*) έΑΦ Mozilla Firefox$": "ΎΚσ  $1",
			"^Mozilla Firefox$": "ΎΚσ ",
			"^Discord \\| (.*)": "≤░βψ  $1",
			"^έΑλ Discord \\| (.*)": "≤░βψ  έΑλ $1",
			"^\\(([0-9]+)\\) Discord \\| (.*)": "≤░βψ  ($1) $2"
		},
	},
	"niri/window": {
		"format": "{}",
		"rewrite": {
			"(.*) έΑΦ Mozilla Firefox$": "ΎΚσ  $1",
			"^Mozilla Firefox$": "ΎΚσ ",
			"^Discord \\| (.*)": "≤░βψ  $1",
			"^έΑλ Discord \\| (.*)": "≤░βψ  έΑλ $1",
			"^\\(([0-9]+)\\) Discord \\| (.*)": "≤░βψ  ($1) $2"
		},
	},
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "ΎΑμ",
            "unlocked": "ΎΓε"
        }
    },
    "mpd": {
        "format": "<span>{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) έ╕ρ{songPosition}|{queueLength}έ╕σ {volume}% ΎΑΒ</span>",
        "format-disconnected": "Disconnected ΎΑΒ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ΎΑΒ",
        "unknown-tag": "",
        "interval": 2,
        "consume-icons": {
            "on": "ΎΔΕ "
        },
        "random-icons": {
            "off": "",
            "on": "ΎΒ┤ "
        },
        "repeat-icons": {
            "on": "ΎΑη "
        },
        "single-icons": {
            "on": "ΎΑη1 "
        },
        "state-icons": {
            "paused": "ΎΒΝ",
            "playing": "ΎΒΜ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%H:%M %Y-%m-%d}",
        "calendar": {
                    "mode"          : "month",
                    "mode-mon-col"  : 3,
                    "weeks-pos"     : "",
                    "on-scroll"     : 1,
                    "format": {
                              "months":     "<span color='#ffead3'><b>{}</b></span>",
                              "days":       "<span color='#ecc6d9'>{}</span>",
                              "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff6699'><b>{}</b></span>"
                              }
                    }
    },
    "cpu": {
        "format": "{usage}% ΎΜδ",
        "tooltip": false
    },
    "memory": {
        "format": "{}% Ό┐Ζ"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["ΎΜΜ", "ΎΜΚ", "Ό╝ς"]
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
        "format-muted": "Όυν ",
        "format-source": "{volume}% ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "Ό╣β",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol",
		"on-scroll-up": "~/.config/bin/adjust_volume +1",
		"on-scroll-down": "~/.config/bin/adjust_volume -1"
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "ΎΗ╝",
            "default": "ΏθΟε"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
	"custom/notif": {
		"tooltip": false,
		"format": "{icon}",
		"format-icons": {
		  "notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
		  "none": "ΎΓλ",
		  "dnd-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
		  "dnd-none": "ΎΘ╖",
		  "inhibited-notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
		  "inhibited-none": "ΎΓλ",
		  "dnd-inhibited-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
		  "dnd-inhibited-none": "ΎΘ╖"
		},
		"return-type": "json",
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		"on-click": "swaync-client -t -sw",
		"on-click-right": "swaync-client -d -sw",
		"escape": true
	}
}]
